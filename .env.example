# =============================================================================
# Container runtime (src/start.sh)
# =============================================================================
# Set to "true" to run handler with `--rp_serve_api` on 0.0.0.0 for local/API testing.
SERVE_API_LOCALLY=

# =============================================================================
# S3 upload after training (RunPod runpod-python rp_upload.get_boto_client)
# =============================================================================
# Anifusion dispatches jobs without top-level `s3Config`; the worker uses env vars here.
# See site-packages/runpod/serverless/utils/rp_upload.py — when bucket_creds is None it reads:
#   BUCKET_ENDPOINT_URL, BUCKET_ACCESS_KEY_ID, BUCKET_SECRET_ACCESS_KEY
#
# Optional: per-job overrides via top-level `s3Config` on the RunPod job (endpointUrl, accessId,
# accessSecret, bucketName) — only if your caller sends it; Anifusion currently does not.

BUCKET_ENDPOINT_URL=
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=
